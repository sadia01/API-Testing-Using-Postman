							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.email).to.eql(pm.environment.get(\"Email\"));\r",
							"});\r",
							"pm.test(\"Message Validated\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.message).to.eql(\"We have emailed your verification code.\");\r",
